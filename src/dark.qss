* {
    background-color: #2b2b2b;
    color: #e0e0e0;
}

#mainTabBar {
    background-color: #2b2b2b;
}

#mainTabBar::tab {
    background-color: #4b4e50;
    color: #e0e0e0;
    padding: 8px 12px;
    border: 1px solid #666666;
    border-bottom: none;
}

#mainTabBar::tab:selected {
    background-color: #2b2b2b;
    border-bottom: 2px solid #55aaff;
}

#mainTabBar::tab:hover {
    background-color: #5d6062;
}
